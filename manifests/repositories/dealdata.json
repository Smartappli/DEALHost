{
  "name": "DEALData",
  "slug": "dealdata",
  "repository_full_name": "Smartappli/DEALData",
  "allowed_events": [
    "push"
  ],
  "path_mappings": [
    {
      "prefix": "core_layer/",
      "module_slug": "dealdata-core-layer"
    },
    {
      "prefix": "gps_layer/",
      "module_slug": "dealdata-gps-layer"
    },
    {
      "prefix": "sensor_layer/",
      "module_slug": "dealdata-sensor-layer"
    },
    {
      "prefix": "docker-compose",
      "module_slug": "dealdata-platform"
    },
    {
      "prefix": ".github/",
      "module_slug": "dealdata-platform"
    }
  ],
  "route_defaults": [
    {
      "module_slug": "dealdata-core-layer",
      "public_path": "/dealdata/core",
      "upstream_host": "dealdata-core",
      "upstream_port": 7000
    },
    {
      "module_slug": "dealdata-gps-layer",
      "public_path": "/dealdata/gps",
      "upstream_host": "dealdata-gps",
      "upstream_port": 7001
    },
    {
      "module_slug": "dealdata-sensor-layer",
      "public_path": "/dealdata/sensor",
      "upstream_host": "dealdata-sensor",
      "upstream_port": 7002
    }
  ]
}
